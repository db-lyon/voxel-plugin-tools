{
  "name": "voxel-plugin-tools",
  "version": "0.4.0",
  "description": "Voxel Plugin actions for ue-mcp. Cited to the C++ headers each action wraps; full reference under docs/.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "ue-mcp.plugin.yml",
    "knowledge",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ue-mcp-plugin",
    "unreal-engine",
    "ue5",
    "voxel",
    "voxel-plugin",
    "pcg",
    "landscape"
  ],
  "author": "David Lyon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/db-lyon/voxel-plugin-tools.git"
  },
  "peerDependencies": {
    "ue-mcp": ">=1.0.15"
  },
  "devDependencies": {
    "ue-mcp": "^1.0.71",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "check": "node scripts/static-check.mjs && node scripts/schema-drift-check.mjs",
    "prepublishOnly": "npm run build && npm run check"
  },
  "engines": {
    "node": ">=18"
  }
}
